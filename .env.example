# Fintual - usa tu email y contraseña de Fintual
FINTUAL_EMAIL=tu@email.com
FINTUAL_PASSWORD=tu_contraseña

# Binance - crea una API key en https://www.binance.com/en/my/settings/api-management
# Solo necesita permiso "Read Info" (sin trading)
BINANCE_API_KEY=tu_api_key
BINANCE_API_SECRET=tu_api_secret

# Google Gemini - obtén tu clave GRATIS en https://aistudio.google.com → "Get API key"
GEMINI_API_KEY=tu_gemini_key
