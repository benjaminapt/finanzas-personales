# Copia este archivo como referencia para configurar los secrets en Streamlit Cloud.
# En Streamlit Cloud: Settings → Secrets → pegar el contenido con tus valores reales.
# Localmente: estos valores van en el .env (NO en este archivo).

DATABASE_URL = "postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"

BINANCE_API_KEY = "tu_api_key_de_binance"
BINANCE_API_SECRET = "tu_api_secret_de_binance"

GEMINI_API_KEY = "tu_gemini_api_key"

# FINTUAL_EMAIL y FINTUAL_PASSWORD NO son necesarios en la nube.
# Fintual se sincroniza desde tu Mac local con: python3 -m cli.main sync
